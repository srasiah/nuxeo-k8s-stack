# PostgreSQL Secret Configuration
# Copy this file to .env.postgres.secret and update with your actual credentials
# The .env.postgres.secret file is gitignored for security

# PostgreSQL database credentials
postgres-username=postgres
postgres-password=postgres123
postgres-database=nuxeo

# pgAdmin web interface credentials
pgadmin-email=pgadmin@example.com
pgadmin-password=pgadmin123
